{
  "title": "DesignTokens",
  "type": "object",
  "required": ["colors", "typography", "spacing", "meta"],
  "additionalProperties": false,
  "properties": {
    "colors": {
      "type": "object",
      "required": ["brand", "neutral"],
      "additionalProperties": false,
      "properties": {
        "brand": {
          "type": "object",
          "required": ["primary", "onPrimary"],
          "additionalProperties": false,
          "properties": {
            "primary": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})$" },
            "onPrimary": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})$" }
          }
        },
        "neutral": {
          "type": "object",
          "required": ["background", "surface", "textPrimary", "textSecondary", "border", "tint"],
          "additionalProperties": false,
          "properties": {
            "background": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})$" },
            "surface": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})$" },
            "textPrimary": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})$" },
            "textSecondary": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})$" },
            "border": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})$" },
            "tint": { "type": "string", "enum": ["brand", "cool", "warm", "neutral"] }
          }
        }
      }
    },
    "typography": {
      "type": "object",
      "required": ["fontFamily", "baseFontSize", "scaleRatio"],
      "additionalProperties": false,
      "properties": {
        "fontFamily": { "type": "string", "minLength": 1, "maxLength": 120 },
        "baseFontSize": { "type": "number", "minimum": 8, "maximum": 40 },
        "scaleRatio": { "type": "number", "minimum": 1.0, "maximum": 2.0 }
      }
    },
    "spacing": {
      "type": "object",
      "required": ["baseUnit"],
      "additionalProperties": false,
      "properties": {
        "baseUnit": { "type": "number", "minimum": 1, "maximum": 20 }
      }
    },
    "meta": {
      "type": "object",
      "required": ["generatedBy", "method", "timestamp"],
      "additionalProperties": true,
      "properties": {
        "generatedBy": { "type": "string" },
        "method": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    }
  }
}
